"""Repository rules that download tectonic binaries.

These are invoked by the `tectonic` module extension (see extensions.bzl) to
materialise one repository per (os, cpu) platform pair.
"""

load(
    "//latex/private:versions.bzl",
    "TECTONIC_RELEASES",
    "TECTONIC_VERSION",
    "tectonic_download_url",
)

_TECTONIC_BUILD_FILE = """\
# Auto-generated by rules_latex.
load("@rules_latex//latex/toolchain:toolchain.bzl", "latex_toolchain")

package(default_visibility = ["//visibility:public"])

exports_files(["tectonic"])

latex_toolchain(
    name = "toolchain",
    tectonic = ":tectonic",
)
"""

def _tectonic_repository_impl(rctx):
    spec = TECTONIC_RELEASES.get((rctx.attr.os, rctx.attr.cpu))
    if spec == None:
        fail("rules_latex has no tectonic release pinned for os={} cpu={}".format(
            rctx.attr.os,
            rctx.attr.cpu,
        ))

    url = tectonic_download_url(spec.asset, version = TECTONIC_VERSION)
    rctx.download_and_extract(
        url = url,
        sha256 = spec.sha256,
        stripPrefix = "",
    )

    # The extracted archive places `tectonic` (or `tectonic.exe` on Windows)
    # at the top level. We sanity-check it exists.
    if not rctx.path("tectonic").exists:
        fail("expected tectonic executable not found in archive {}".format(url))

    rctx.file("BUILD.bazel", _TECTONIC_BUILD_FILE)

tectonic_repository = repository_rule(
    implementation = _tectonic_repository_impl,
    doc = "Downloads a platform-specific tectonic binary release.",
    attrs = {
        "os": attr.string(mandatory = True, values = ["linux", "macos", "windows"]),
        "cpu": attr.string(mandatory = True, values = ["x86_64", "aarch64"]),
    },
)
